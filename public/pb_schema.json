    "viewQuery": "SELECT\n    ar.worker_id,\nDATE(ar.check_in,'localtime') AS work_date,\n    (SUM(STRFTIME('%s', ar.check_out) - STRFTIME('%s', ar.check_in)) / 3600.0) AS total_work_hours,\n  (ROW_NUMBER() OVER()) as id\nFROM\n    attendance_record_test ar\nWHERE check_in IS NOT \"\" AND check_out IS NOT \"\"\nGROUP BY\n    ar.worker_id,\n    DATE(ar.check_in,\"localtime\")\nORDER BY\n    ar.worker_id,\n    work_date;\n"
  },
