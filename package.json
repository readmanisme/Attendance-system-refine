{
  "name": "Attendance-system-refine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "refine dev",
    "dev2": "vite dev",
    "dev-profile": "vite dev --profile --open",
    "build": "powershell -Command \"$date = Get-Date -Format 'yyyy-MM-dd_HH-mm-ss'; mkdir -Force logs; function Strip-ANSI { $input -replace '\\e\\[[0-9;]*m', '' }; npx tsc --noEmit 2>&1 | Strip-ANSI | Tee-Object -FilePath logs/build-$date.log; if ($LASTEXITCODE -eq 0) { npx vite build 2>&1 | Strip-ANSI | Tee-Object -FilePath logs/build-$date.log -Append } else { Write-Error 'TypeScript compilation failed' }\"",
    "build-debug": "vite build -d",
    "build-profile": "vite build --profile --open",
    "start": "vite preview",
    "refine": "refine",
    "scan": "npx react-scan localhost:5173",
    "format": "npx prettier --write src/",
    "eslint": "npx eslint --ext .ts,.tsx src/",
    "cyopen": "cypress open"
  },
